---
interface Props {
  class?: string;
  width?: string | number;
  height?: string | number;
}

const { width = "24", height, class: className } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  class={className}
  width={width}
  height={height}
  fill="none"
  viewBox="0 0 24 24"
>
  <title>Link icon</title>
  <path
    stroke="#fff"
    stroke-linecap="round"
    stroke-linejoin="round"
    stroke-width="2"
    d="M10 4H6a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-4m-8-2 8-8m0 0v5m0-5h-5"
  ></path>
</svg>
