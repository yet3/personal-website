---
import CommentParagraph from "$common/comment-paragraph.svelte";
import ProjectActions from "$common/project-actions.astro";
import ProjectImg from "$common/project-img.astro";
import type { IProject } from "@repo/content/projects";

interface Props {
  idx: number;
  project: IProject;
}

const { idx, project } = Astro.props;
const images = project.images ?? [];

const mainHref = project.appHref ?? project.repoHref ?? "#";
---

<li>
  {
    images.length > 0 && (
      <ProjectImg
        class="animate-center-scale-in will-change-transform"
        src={images[0].src}
        href={mainHref}
        blurhash={images[0].blurhash}
        delay={`calc(var(--delay-projects-preview) + ${200 + idx * 100}ms)`}
      />
    )
  }
  <div class="animate-left-scale-in delay-proj-prev-100 mt-1 flex flex-col">
    <p
      class="animate-text-glitch-hover mb-2 w-fit text-lg font-semibold delay-0"
      data-text={project.title}
    >
      {project.title}
    </p>

    {
      project.contentBlocks.map((block) => (
        <CommentParagraph class="text-primary-300 text-sm">
          {block}
        </CommentParagraph>
      ))
    }
    <ProjectActions
      class="mt-4"
      appHref={project.appHref}
      repoHref={project.repoHref}
    />
  </div>
</li>
