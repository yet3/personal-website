---
import type { IProject } from "@repo/content/projects";
import SkillBadgeById from "$common/skill-badge-by-id.svelte";
import ProjectImg from "$common/project-img.astro";
import ProjectActions from "$common/project-actions.astro";
import CommentParagraph from "$common/comment-paragraph.svelte";

interface Props {
  idx: number;
  project: IProject;
}

const { idx, project } = Astro.props;
const images = project.images ?? [];

const imgOnEnd = idx % 2 === 0;
const mainHref = project.appHref ?? project.repoHref ?? "#";

const makeDelay = (delay: number = 0) => {
  return `calc(var(--delay-projects) + ${200 + delay + idx * 200}ms)`;
};
const makeDelayStyle = (delay: number = 0) => {
  return `--delay: ${makeDelay(delay)};`;
};
---

<li
  class:list={{
    "max-md:(max-w-128 mx-auto) grid items-center gap-4": true,
    "md:grid-cols-[1fr_0.8fr]": imgOnEnd,
    "md:grid-cols-[0.8fr_1fr]": !imgOnEnd,
  }}
>
  <div>
    <p
      class="animate-top-slide-in animate-text-glitch-hover text-lg font-semibold"
      data-text={project.title}
      style={makeDelayStyle()}
    >
      {project.title}
    </p>
    <div class="animate-top-slide-in mt-1 mb-1" style={makeDelayStyle(100)}>
      {
        project.contentBlocks.map((block) => (
          <CommentParagraph class="text-primary-300">{block}</CommentParagraph>
        ))
      }
    </div>
    <ul
      class="animate-top-slide-in mt-3 -mr-2 flex flex-wrap"
      style={makeDelayStyle(200)}
    >
      {
        project.skills.map((skillId) => (
          <li class="mr-2 mb-2 flex items-center">
            <SkillBadgeById id={skillId} />
          </li>
        ))
      }
    </ul>
  </div>
  <div class:list={{ "max-md:order-first": true, "md:order-first": !imgOnEnd }}>
    {
      images.length > 0 && (
        <ProjectImg
          class="animate-center-scale-in mx-auto"
          src={images[0].src}
          href={mainHref}
          blurhash={images[0].blurhash}
          delay={makeDelay(200)}
        />
      )
    }
    <ProjectActions
      class="mt-4"
      appHref={project.appHref}
      repoHref={project.repoHref}
      delay={makeDelay(300)}
    />
  </div>
</li>
